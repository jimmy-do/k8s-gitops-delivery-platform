# Terraform
.terraform/
.terraform*
!/.terraform.lock.hcl
!/infrastructure-cicd/terraform/*/.terraform.lock.hcl
!/infrastructure-cicd/terraform/*/*/.terraform.lock.hcl
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
terraform.tfvars
*.auto.tfvars

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Helm
*.tgz

# Kubernetes & Secrets
*secret*.yaml
*secrets*.yaml
!observability/**/templates/*secret*.yaml
!observability/**/templates/*secrets*.yaml
kubeconfig
*.kubeconfig
.kube/

# Cloud & Local Env
.aws/
.env
.env*

# OS & IDE
.DS_Store
*.swp
.vscode/
.idea/

# ArgoCD sensitive configs
argocd-credentials.yaml

# Terraform (Phase 2 additions)
*.tfvars.example
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Bootstrap exception — state bucket can't store its own creation state
!infrastructure-cicd/terraform/bootstrap/terraform.tfstate
!infrastructure-cicd/terraform/bootstrap/terraform.tfstate.backup

# .terraform.lock.hcl is intentionally committed — pins provider versions
